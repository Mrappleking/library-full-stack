generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ 枚举 ============

enum UserRole {
  admin
  reader
}

enum BookStatus {
  available
  borrowed
  removed
}

enum ItemCondition {
  normal
  damaged
  repairing
  lost
  withdrawn
}

enum ItemStatus {
  available
  borrowed
  repairing
  lost
  withdrawn
  on_hold
}

enum FineType {
  overdue
  lost
  damage
}

// ============ 用户体系 ============

model PatronCategory {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(50)    // 本科生 / 研究生 / 教师
  createdAt  DateTime @default(now()) @map("created_at")

  users             User[]
  circulationRules  CirculationRule[]

  @@map("patron_categories")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(50)
  password  String    @db.VarChar(255)
  name      String    @db.VarChar(100)
  role      UserRole  @default(reader)
  phone     String?   @db.VarChar(20)
  email     String?   @db.VarChar(100)
  totalFines Decimal   @default(0) @db.Decimal(10, 2) @map("total_fines")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  patronCategoryId Int?
  patronCategory   PatronCategory? @relation(fields: [patronCategoryId], references: [id])

  borrowRecords BorrowRecord[]
  fines         Fine[]

  @@map("users")
}

// ============ 资料类型 + 分类 ============

model ItemType {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)   // 普通图书 / 新书速递 / 期刊 / 工具书
  loanDays  Int      @default(30)               // 默认借阅天数
  fineRate  Decimal  @default(0.10) @db.Decimal(10, 2) // 日罚金（元）
  createdAt DateTime @default(now()) @map("created_at")

  bookItems        BookItem[]
  circulationRules CirculationRule[]

  @@map("item_types")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(100)
  desc      String?   @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  books Book[]

  @@map("categories")
}

// ============ 借阅规则引擎 ============

model CirculationRule {
  id                Int      @id @default(autoincrement())
  patronCategoryId  Int
  itemTypeId        Int
  maxBorrows        Int      @default(5)
  loanDays          Int      @default(30)
  renewals          Int      @default(1)
  renewalDays       Int      @default(15)
  finePerDay        Decimal  @default(0.10) @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  patronCategory PatronCategory @relation(fields: [patronCategoryId], references: [id])
  itemType       ItemType       @relation(fields: [itemTypeId], references: [id])

  @@unique([patronCategoryId, itemTypeId])
  @@map("circulation_rules")
}

// ============ 图书体系 ============

model Book {
  id         Int        @id @default(autoincrement())
  isbn       String     @unique @db.VarChar(20)
  title      String     @db.VarChar(200)
  author     String     @db.VarChar(100)
  publisher  String?    @db.VarChar(200)
  year       Int?
  total      Int        @default(1)
  available  Int        @default(1)
  status     BookStatus @default(available)
  location   String?    @db.VarChar(100)
  cover      String?    @db.VarChar(500)
  desc       String?    @db.Text
  clcNumber    String?    @db.VarChar(50)  // 中图法分类号 TP36
  physicalDesc String?    @db.VarChar(200) // 载体形态 "169页"
  language     String?    @db.VarChar(10)  // chi/eng/jpn
  country      String?    @db.VarChar(10)  // CN/US/JP
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  items         BookItem[]
  borrowRecords BorrowRecord[]

  @@map("books")
}

model BookItem {
  id           Int          @id @default(autoincrement())
  barcode      String       @unique @db.VarChar(30)        // 条码号 LIB-000101
  callNumber   String?      @db.VarChar(100)               // 索书号 TP312/1002
  location     String?      @db.VarChar(100)               // 馆藏地 总馆A区3楼
  condition    ItemCondition @default(normal)
  status       ItemStatus   @default(available)
  price        Decimal?     @db.Decimal(10, 2)             // 购入价格
  acquiredAt   DateTime?    @map("acquired_at")             // 入藏日期
  notes        String?      @db.VarChar(500)               // 备注
  campus       String?      @db.VarChar(50)                // 校区 (青岛/泰安/济南)
  requests     Int          @default(0)                    // 当前请求数
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  bookId     Int
  book       Book     @relation(fields: [bookId], references: [id])
  itemTypeId Int
  itemType   ItemType @relation(fields: [itemTypeId], references: [id])

  borrowRecords BorrowRecord[]

  @@map("book_items")
}

// ============ 借阅体系 ============

model BorrowRecord {
  id         Int       @id @default(autoincrement())
  borrowDate DateTime  @default(now()) @map("borrow_date")
  dueDate    DateTime  @map("due_date")
  returnDate DateTime? @map("return_date")
  renewed    Boolean   @default(false)
  status     String    @default("active") @db.VarChar(20) // active / returned / overdue
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  userId Int
  user   User @relation(fields: [userId], references: [id])

  bookId Int
  book   Book @relation(fields: [bookId], references: [id])

  bookItemId Int?
  bookItem   BookItem? @relation(fields: [bookItemId], references: [id])

  fines Fine[]

  @@map("borrow_records")
}

// ============ 罚款体系 ============

model Fine {
  id         Int       @id @default(autoincrement())
  amount     Decimal   @db.Decimal(10, 2)                     // 金额
  paid       Boolean   @default(false)                        // 是否已缴
  paidAt     DateTime? @map("paid_at")                        // 缴费时间
  createdAt  DateTime  @default(now()) @map("created_at")

  borrowRecordId Int
  borrowRecord   BorrowRecord @relation(fields: [borrowRecordId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  type FineType @default(overdue)

  @@map("fines")
}
